# انسخ هذا الملف إلى .env واملأ القيم الحقيقية — لا ترفع .env إلى git أبداً

# PostgreSQL (محلي أو سحابي)
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/abdullahdb

SESSION_SECRET=change-me
PORT=5000

# تسجيل دخول محلي
LOCAL_ADMIN_EMAIL=admin@local.dev
LOCAL_ADMIN_PASSWORD=change-me

# MongoDB (محلي أو Atlas)
MONGODB_URI=mongodb://localhost:27017/abdullahdb

# JWT
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
