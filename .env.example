# Production Environment Variables Example

# Server Configuration
NODE_ENV=production
PORT=5000
SESSION_SECRET=your_random_session_secret_here

# MongoDB Connection
# Replace with your Atlas connection string or local MongoDB URI
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Authentication & Security
JWT_SECRET=your_long_random_jwt_secret_here
JWT_REFRESH_SECRET=your_long_random_refresh_secret_here
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email Configuration (Optional - uncomment to use)
# RESEND_API_KEY=re_123456789
# EMAIL_FROM=contact@yourdomain.com

# Admin Access
LOCAL_ADMIN_EMAIL=admin@yourdomain.com
LOCAL_ADMIN_PASSWORD=change_this_password_immediately
